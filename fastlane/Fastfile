default_platform(:android)

platform :android do
  desc "Upload store listing metadata and images to Google Play"
  lane :update_listing do
    supply(
      track: "internal",
      metadata_path: "fastlane/metadata/android",
      images_path: "fastlane/metadata/android/en-US/images"
    )
  end

  desc "Upload a new APK/AAB to Google Play"
  lane :upload_build do
    gradle(task: "bundleRelease")
    supply(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab"
    )
  end
end
